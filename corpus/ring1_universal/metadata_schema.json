{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ibis Corpus Entry Schema",
  "description": "Metadata schema for a single Project Ibis corpus entry",
  "type": "object",
  "required": [
    "id",
    "text",
    "source",
    "ring",
    "tradition",
    "culture",
    "region",
    "language",
    "original_language",
    "values_tags",
    "domain",
    "format",
    "universality_score",
    "license",
    "date_added",
    "added_by",
    "preferred"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ibis-(univ|phil|appl|wisd)-[0-9]{4}$",
      "examples": ["ibis-univ-0001", "ibis-phil-0042", "ibis-appl-0010", "ibis-wisd-0007"]
    },
    "text": {
      "type": "string",
      "minLength": 20,
      "maxLength": 2000,
      "examples": [
        "All human beings are born free and equal in dignity and rights.",
        "Do not do to others what you would not want done to yourself.",
        "A person is a person through other persons — I am because we are.",
        "The earth does not belong to us. We belong to the earth.",
        "One who injures others injures themselves.",
        "Act only according to that maxim by which you can at the same time will that it should become a universal law.",
        "An eye for an eye makes the whole world blind.",
        "We are all leaves of one tree. We are all waves of one sea."
      ]
    },
    "rejected_contrast_file": {
      "type": ["string", "null"],
      "examples": [
        "./contrasts/udhr-rejected.txt",
        "./contrasts/analects-rejected.txt",
        "./contrasts/dhammapada-rejected.txt"
      ]
    },
    "source": {
      "type": "string",
      "examples": [
        "Universal Declaration of Human Rights — Article 1",
        "Nicomachean Ethics — Aristotle, Book II",
        "Analects of Confucius — Book XII, Chapter 1",
        "Dhammapada — Verse 1",
        "Bhagavad Gita — Chapter 3, Verse 19",
        "Masnavi — Rumi, Book I",
        "Tao Te Ching — Laozi, Chapter 8",
        "Meditations — Marcus Aurelius, Book IV",
        "Ubuntu Philosophy — Nguni Bantu oral tradition",
        "Hippocratic Oath — Classical version",
        "Torah — Leviticus 19:18",
        "Quran — Surah 4:135",
        "Upanishads — Brihadaranyaka, 1.4.14",
        "Jain Agamas — Acaranga Sutra",
        "Zhuangzi — Inner Chapters",
        "Kojiki — Book I",
        "Popol Vuh — Part I",
        "Havamal — Norse Eddic poem, verse 77",
        "Emerald Tablet — Hermetic tradition",
        "Gathas — Avesta, Yasna 30",
        "Code of Ma'at — Ancient Egyptian wisdom texts",
        "Instruction of Amenemope — Ancient Egyptian",
        "Epic of Gilgamesh — Tablet X",
        "Mwindo Epic — Nyanga oral tradition, DRC",
        "Seven Grandfather Teachings — Anishinaabe oral tradition",
        "Mitakuye Oyasin — Lakota oral tradition",
        "Pachamama — Andean / Quechua oral tradition",
        "Te Ao Mārama — Māori cosmological tradition",
        "Songlines — Australian Aboriginal oral tradition",
        "Bwiti teachings — Fang people, Gabon",
        "Sikh Rehat Maryada — Guru Granth Sahib",
